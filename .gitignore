# --- MLflow e Modelos ---
# Ignora os rastreios locais do MLflow para não poluir o git do professor
mlruns/
# Ignora os artefatos de modelos treinados (pesados e binários)
models/*.pt
models/*.pkl
notebooks/mlruns/
mlflow.db

# --- Docker ---
# Geralmente não ignoramos o Dockerfile, mas podemos ignorar dados persistidos
.docker/

# --- Cache do Python e Ferramentas ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/

# --- Dados e Logs ---
# Ignora o banco de dados SQLite local gerado pelo processo
data/processed/*.db
# Ignora logs de execução
logs/*.log
# Ignora arquivos de dados brutos pesados (opcional, se não forem necessários no git)
data/raw/*.csv
data/raw/*.xlsx